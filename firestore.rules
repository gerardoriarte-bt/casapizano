rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: surveyResults
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (optional) - The UID of the user
    //   - userName: string (required) - The name provided by the user
    //   - inhabitants: number (optional) - Number of people
    //   - ages: string (optional) - Ages of inhabitants
    //   - pets: string (optional) - Pets info
    //   - answers: map (optional) - User's answers
    //   - scores: map (optional) - Profile scores
    //   - dominantProfile: string (required) - The winning profile
    //   - clientReport: string (optional) - Aspirational text
    //   - architectReport: string (optional) - Technical text
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSurveyResult(data) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.dominantProfile is string &&
             data.createdAt is timestamp;
    }

    match /surveyResults/{resultId} {
      // Allow anyone to create a survey result (even unauthenticated for lead gen)
      // But if they are authenticated, we link it to their UID
      allow create: if isValidSurveyResult(request.resource.data);
      
      // Only the owner or an admin can read their own results
      allow read: if (request.resource.data.userId != null && isOwner(request.resource.data.userId)) || isAdmin();
      
      // No updates allowed for now to keep results immutable
      allow update: if false;
      
      // Only admin can delete
      allow delete: if isAdmin();
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gerardo.riarte@buentipo.com" && request.auth.token.email_verified == true));
    }
  }
}
