# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# En local: server.ts (npm run dev). En Vercel: variable de entorno del proyecto → api/generate-manifest.
OPENAI_API_KEY=your_openai_api_key_here
VITE_FIREBASE_API_KEY=...

# RESEND_API_KEY: Required for sending emails via Resend.
RESEND_API_KEY="re_..."

# STUDIO_EMAIL: The email address where the architectural report will be sent.
STUDIO_EMAIL="arquitectura@pizano.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Opcional: URL de una Google Apps Script "Web app" (POST JSON) que añade filas a una hoja.
# Si está vacío, el servidor responde { ok: true, skipped: true } y la app sigue funcionando.
GOOGLE_SHEETS_WEBHOOK_URL=
